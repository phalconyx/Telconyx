# Required (single-bot mode): Telegram bot token from @BotFather
TELCONYX_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Required (single-bot mode): target chat (group/channel ID like -1001234567890, or @groupusername)
TELCONYX_CHAT_ID=-1001234567890

# Optional: multiple bot/chat routes for load distribution. When set, this
# replaces TELCONYX_BOT_TOKEN/TELCONYX_CHAT_ID. Format: comma-separated
# "alias=token@chat_id" entries. For a @username chat, keep its "@":
# "b2=456:XYZ@@mygroup". Uploads rotate over routes (round robin, skipping
# rate-limited ones); each telconyx:// link records its route alias so
# downloads/deletes go back to the same bot. Aliases are permanent: renaming
# or removing one breaks the links that reference it.
#TELCONYX_ROUTES=b1=1234567890:ABCdef@-1001111111111,b2=9876543210:XYZabc@-1002222222222

# Optional: route alias used for links that carry no route marker (links made
# before TELCONYX_ROUTES existed). Point this at the route holding your
# original bot when migrating. Default: the first route.
#TELCONYX_DEFAULT_ROUTE=b1

# Optional: API key for HTTP server auth. If set, clients must send X-API-Key.
# Generate one with:  openssl rand -hex 32
TELCONYX_API_KEY=

# Optional: HTTP listen address (default :9090)
TELCONYX_LISTEN=:9090

# Optional: per-request HTTP timeout (default 60s)
TELCONYX_TIMEOUT=60s

# Optional: maximum total upload size in bytes. Lettered suffixes (B, K/KB,
# M/MB, G/GB, KiB, MiB, GiB) are all binary (powers of 1024).
# "49MB" == 49 * 1024 * 1024 bytes. For decimal bytes, use a bare number.
# Default: 2GB
TELCONYX_MAX_UPLOAD_SIZE=2GB

# Optional: maximum total download size. Same format as MAX_UPLOAD_SIZE.
# Default: 2GB
TELCONYX_MAX_DOWNLOAD_SIZE=2GB

# Optional: chunk size for split uploads. Must be <= 50MB.
# Default: 49MB
TELCONYX_CHUNK_SIZE=49MB

# Optional: number of concurrent chunk downloads (1+).
# Default: 3
TELCONYX_CHUNK_CONCURRENCY=3
